# Neon Postgres connection string (pooled, HTTP-driver compatible).
# Get it from the Neon dashboard → your project → Connection Details.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Random long secret used to sign the unlock token (HMAC). Generate with:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Created automatically when you add a Vercel Blob store to the project
# (Vercel → Storage → Create Database → Blob). Copy it here for local `vercel dev`.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Initial admin password, used only once by `npm run migrate` to seed the
# `settings` table if no password hash exists yet. Change it from the app
# afterwards (⚙️ button) — this env var is not read again after migration.
ADMIN_PASSWORD=DuongDomino
